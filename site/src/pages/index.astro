---
import Hero from '../components/Hero.astro';
import CardTile from '../components/CardTile.astro';
import Filter from '../components/Filter.astro';
import { cards, totalClips } from '../data/cards';

const uniqueSets = Array.from(new Set(cards.map((card) => card.set))).sort();
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hearthstone Sound Pack</title>
  </head>
  <body>
    <main class="shell">
      <Hero cardCount={cards.length} clipCount={totalClips} />
      <Filter sets={uniqueSets} />
      <section class="grid" aria-label="Mapped cards">
        {cards.map((card) => (
          <CardTile card={card} data-set={card.set} />
        ))}
      </section>
    </main>

    <script src="../scripts/player.ts"></script>
    <script>
      const filterSelect = document.getElementById('set-filter') as HTMLSelectElement;
      const cards = document.querySelectorAll<HTMLElement>('.card');

      filterSelect?.addEventListener('change', (e) => {
        const selectedSet = (e.target as HTMLSelectElement).value;

        cards.forEach((card) => {
          const cardSet = card.dataset.set;
          if (selectedSet === 'all' || cardSet === selectedSet) {
            card.style.display = 'grid';
          } else {
            card.style.display = 'none';
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f1425;
    --panel: rgba(20, 29, 52, 0.88);
    --panel-border: rgba(255, 212, 132, 0.18);
    --text: #f8f0dc;
    --muted: #cbbd9b;
    --accent: #ffcb67;
    --accent-strong: #f29a2e;
    --focus: #8ed8ff;
    --shadow: 0 18px 45px rgba(0, 0, 0, 0.35);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: Georgia, 'Times New Roman', serif;
    color: var(--text);
    background:
      radial-gradient(circle at top, rgba(88, 122, 212, 0.2), transparent 36%),
      linear-gradient(180deg, #1b2139 0%, #0f1425 45%, #090d18 100%);
  }

  a {
    color: inherit;
  }

  .shell {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 4rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.2rem;
  }

  @media (max-width: 640px) {
    .shell {
      width: min(100% - 1rem, 34rem);
      padding-top: 1.5rem;
    }
  }
</style>
