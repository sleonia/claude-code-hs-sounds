---
import Hero from "../components/Hero.astro";
import CardTile from "../components/CardTile.astro";
import Filter from "../components/Filter.astro";
import GridWrapper from "../components/GridWrapper.astro";
import { cards, totalClips } from "../data/cards";

const uniqueSets = Array.from(new Set(cards.map((card) => card.set))).sort();
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hearthstone Sound Pack</title>
  </head>
  <body>
    <main class="shell">
      <Hero cardCount={cards.length} clipCount={totalClips}>
        <Filter sets={uniqueSets} />
      </Hero>
      <GridWrapper>
        <section class="grid" aria-label="Mapped cards">
          {cards.map((card) => <CardTile card={card} data-set={card.set} />)}
        </section>
      </GridWrapper>
    </main>

    <script src="../scripts/player.ts"></script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Open Sans";
    src: url("https://fonts.gstatic.com/s/opensans/v36/mem8YaGs126MiZpBA-UFWJ0bbck.woff2")
      format("woff2");
    font-weight: 400;
    font-display: swap;
  }

  @font-face {
    font-family: "Open Sans";
    src: url("https://fonts.gstatic.com/s/opensans/v36/mem5YaGs126MiZpBA-UN7rgOX-hpOqc.woff2")
      format("woff2");
    font-weight: 700;
    font-display: swap;
  }

  @font-face {
    font-family: "Benguiat Bold";
    src: url("/fonts/Benguiat-Bold.woff") format("woff");
    font-display: swap;
  }

  @font-face {
    font-family: "Belwe Bold";
    src: url("/fonts/Belwe-Bold.woff") format("woff");
    font-display: swap;
  }

  :root {
    --hs-bg-dark: #0f0f0f;
    --hs-bg-card: #1a1a1a;
    --hs-gold-primary: #fcd144;
    --hs-gold-secondary: #d4a843;
    --hs-gold-accent: #f29a2e;
    --hs-text-primary: #f8f0dc;
    --hs-text-secondary: #cbbd9b;
    --hs-border-subtle: rgba(255, 203, 103, 0.18);
    --hs-border-strong: rgba(255, 203, 103, 0.4);
    --hs-shadow: 0 18px 45px rgba(0, 0, 0, 0.35);
    --hs-brown-text: #614326;
    --hs-blue-primary: #233a6e;
    --hs-blue-secondary: #3860be;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "Benguiat Bold", Georgia, serif;
    color: var(--hs-text-primary);
    background:
      radial-gradient(circle at top, rgba(35, 58, 110, 0.08), transparent 50%),
      linear-gradient(180deg, #0a0a0a 0%, #0f0f0f 45%, #050505 100%);
  }

  a {
    color: inherit;
  }

  .shell {
    margin: 0;
    padding: 0 0 2rem 0;
    background: url("/bg.jpg");
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
    padding: 0 4rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 768px) {
    .shell {
      width: min(100% - 1rem, 36rem);
      padding: 2rem 0 3rem;
    }

    .grid {
      gap: 1.25rem;
      padding: 0 1rem;
    }
  }
</style>
