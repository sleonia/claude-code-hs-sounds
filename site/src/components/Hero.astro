---
interface Props {
  cardCount: number;
  clipCount: number;
}

const { cardCount, clipCount } = Astro.props;
---

<header class="hero">
  <h1>Hearthstone Sound Pack</h1>
  <p class="intro">Catalog: {cardCount} cards, {clipCount} audio clips from local soundpack files.</p>
  <p class="status" id="status" aria-live="polite">Ready.</p>
</header>

<style>
  .hero {
    margin-bottom: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.6rem;
    color: var(--accent);
    font-size: 0.9rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 12ch;
    font-size: clamp(2.5rem, 5vw, 4.4rem);
    line-height: 0.95;
  }

  .intro {
    max-width: 62ch;
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .status {
    margin: 1.25rem 0 0;
    min-height: 1.5rem;
    color: var(--accent);
    font-size: 0.95rem;
  }
</style>
