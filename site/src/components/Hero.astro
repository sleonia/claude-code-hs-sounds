---
interface Props {
  cardCount: number;
  clipCount: number;
}

const { cardCount, clipCount } = Astro.props;
---

<header class="filter-wrapper">
  <div class="filter-content">
    <div class="header-content">
      <h1 class="site-title">Hearthstone Sound Pack</h1>
      <div class="stats">
        <span class="stat-item">
          <strong>{cardCount}</strong> cards
        </span>
        <span class="stat-separator">•</span>
        <span class="stat-item">
          <strong>{clipCount}</strong> audio clips
        </span>
      </div>
    </div>
    <slot />
  </div>
</header>

<style>
  .filter-wrapper {
    position: relative;
    margin: 0 auto 2rem;
    padding: 11px 4rem 0;
    background: url("/images/filters/bg-filter-middle.svg") repeat-x;
    background-position: top center;
    background-size: 100px 54px;
    min-height: 104px;
    background-color: #2a241e;
    width: 100%;
    box-sizing: border-box;
  }

  .filter-wrapper::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 11px;
    background: url("/images/filters/bg-filter-top.svg") repeat-x;
    background-size: 100px 11px;
  }

  .filter-wrapper::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 11px;
    background: url("/images/filters/bg-filter-bottom.svg") repeat-x;
    background-size: 100px 11px;
  }

  .filter-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0;
    height: 93px;
    position: relative;
    z-index: 1;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .site-title {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1;
    color: #c9a957;
    font-weight: 700;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #d4c4a8;
    font-family:
      var(--hs-font-accent), "Open Sans", Helvetica, Arial, sans-serif;
  }

  .stat-item strong {
    color: #c9a957;
    font-weight: 600;
  }

  .stat-separator {
    color: #6b5a48;
  }

  @media (max-width: 768px) {
    .filter-wrapper {
      padding: 11px 1rem 0;
    }

    .filter-content {
      padding: 0;
      height: auto;
      min-height: 93px;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .site-title {
      font-size: clamp(1.25rem, 4vw, 1.75rem);
    }

    .stats {
      font-size: 0.85rem;
    }
  }
</style>
