---
interface Props {
  sets: string[];
}

const { sets } = Astro.props;
---

<div class="filter-container">
  <label for="set-filter" class="filter-label">Filter by set:</label>
  <select id="set-filter" class="filter-select">
    <option value="all">All sets</option>
    {sets.map((set) => (
      <option value={set}>{set}</option>
    ))}
  </select>
</div>

<style>
  .filter-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: rgba(20, 29, 52, 0.6);
    border: 1px solid var(--panel-border);
    border-radius: 12px;
  }

  .filter-label {
    color: var(--text);
    font-size: 0.95rem;
    font-weight: normal;
  }

  .filter-select {
    min-width: 200px;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    background: rgba(11, 17, 33, 0.9);
    color: var(--text);
    font: inherit;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .filter-select:hover {
    border-color: rgba(255, 203, 103, 0.4);
  }

  .filter-select:focus {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .filter-select option {
    background: #1b2139;
  }
</style>
