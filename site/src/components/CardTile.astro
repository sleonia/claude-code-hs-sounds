---
import type { Card } from "../data/cards";

interface Props {
  card: Card;
  "data-set"?: string;
}

const { card, ...props } = Astro.props;
const hasSource = card.source.length > 0;
const hasImage = card.image.length > 0;
---

<article class="card" {...props}>
  <div class="content">
    <a
      class="card-link"
      href={hasSource ? card.source : "#"}
      aria-disabled={!hasSource || undefined}
    >
      <div class="art">
        {
          hasImage ? (
            <img src={card.image} alt={card.title} loading="lazy" />
          ) : (
            <div class="art-placeholder">No image</div>
          )
        }
      </div>
      <div class="meta">
        <h2 class="title visually-hidden">{card.title}</h2>
      </div>
    </a>
    <div class="actions">
      {
        card.audios.map((clip) => (
          <button
            class="button"
            type="button"
            data-state="idle"
            data-label={clip.label}
            data-path={clip.path}
            data-title={card.title}
            aria-pressed="false"
            aria-label={`Play audio: ${card.title} - ${clip.label}`}
          >
            <img src="/ui/play-button.png" alt="" class="play-icon" />
          </button>
        ))
      }
    </div>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: transparent;
    border-radius: 20px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .content {
    display: grid;
  }

  .card-link {
    display: grid;
    color: inherit;
    text-decoration: none;
  }

  .card-link[aria-disabled="true"] {
    cursor: default;
  }

  .card-link:focus-visible {
    outline: 2px solid var(--hs-gold-primary);
    outline-offset: 2px;
  }

  .art {
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease;

    &:hover {
      filter: drop-shadow(rgba(255, 255, 255, 0.6) 0px 0px 15px);
      transform: scale(1.1);
    }
  }

  .art img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    filter: drop-shadow(rgba(0, 0, 0, 0.6) 0px 3px 3px);
  }

  .art-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: var(--hs-text-secondary);
    font-size: 0.9rem;
  }

  .meta {
    display: grid;
    padding: 0 1rem;
    gap: 0.5rem;
  }

  .title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    color: var(--hs-text-primary);
    font-family: "Open Sans", Helvetica, Arial, sans-serif;
    font-weight: 700;
    transition: color 0.3s ease;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2rem;
    margin-inline: 1.9rem;
    margin-block-start: -1.5rem;
    min-height: 54px;
    position: relative;
    background: transparent;
  }

  .button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 34px;
    min-height: 34px;
    padding: 0;
    border: 0;
    flex: 0 0 36px;
    cursor: pointer;
    position: relative;
    z-index: 2;
    background-color: transparent;
    background-image: none;

    &:hover {
          transform: scale(1.1);
    filter: brightness(1.1);

    }
  }

  .play-icon {
    width: 60px;
    height: auto;
    object-fit: contain;
    pointer-events: none;
    z-index: 1;

  }

  @media (max-width: 640px) {
    .card {
      border-radius: 16px;
    }

    .content {
      gap: 0.8rem;
    }

    .art {
      border-radius: 10px;
    }

    .title {
      font-size: 1.2rem;
    }

    .actions {
      gap: 0.75rem;
      justify-content: center;
    }

    .button {
      width: 34px;
      height: 32px;
      min-height: 32px;
    }

    .play-icon {
      width: 1.2rem;
      height: 1.2rem;
    }
  }
</style>
