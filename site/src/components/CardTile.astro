---
import type { Card } from "../data/cards";

interface Props {
  card: Card;
  "data-set"?: string;
}

const { card, ...props } = Astro.props;
const hasSource = card.source.length > 0;
const hasImage = card.image.length > 0;
---

<article class="card" {...props}>
  <a
    class="card-link"
    href={hasSource ? card.source : "#"}
    aria-disabled={!hasSource || undefined}
  >
    <div class="art">
      {hasImage && <img src={card.image} alt={card.title} loading="lazy" />}
    </div>
    <h2 class="title visually-hidden">{card.title}</h2>
  </a>
  <div class="actions">
    {
      card.audios.map((clip) => (
        <button
          class="button"
          type="button"
          data-state="idle"
          data-label={clip.label}
          data-path={clip.path}
          data-title={card.title}
          aria-pressed="false"
          aria-label={`Play audio: ${card.title} - ${clip.label}`}
        >
          <img src="/ui/play-button.png" alt="" class="play-icon" />
        </button>
      ))
    }
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-rows: auto auto;
    width: 200px;
    height: 280px;
  }

  .content {
    display: grid;
  }

  .card-link {
    display: block;
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
    outline: none;
    text-decoration: none;

    &:hover,
    &:focus {
      transform: scale(1.1);
      filter: drop-shadow(rgba(252, 209, 68, 0.4) 0px 0px 15px);
    }
  }

  .card-link[aria-disabled="true"] {
    cursor: default;
  }

  .art img {
    display: block;
    filter: drop-shadow(rgba(0, 0, 0, 0.6) 0px 3px 3px);
    transition: transform 0.2s ease;
    height: 280px;
    object-fit: cover;
  }

  .art-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: var(--hs-text-secondary);
    font-size: 0.9rem;
  }

  .title {
    transition: color 0.3s ease;
    margin: 0;
    color: var(--hs-text-primary);
    font-weight: 700;
    font-size: 1.35rem;
    line-height: 1.2;
    font-family: "Open Sans", Helvetica, Arial, sans-serif;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 8px;
    border: 2px solid #8d693f;
    border-radius: 5px;
    background: #261d10;
    padding: 10px;
    width: 200px;
  }

  .button {
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    border: 0;
    background: transparent;
    padding: 0;
    width: 36px;
    height: 34px;
    min-height: 34px;

    &:hover,
    &:focus {
      transform: scale(1.1);
      outline: none;
    }
  }

  .play-icon {
    z-index: 1;
    width: 60px;
    height: auto;
    object-fit: contain;
    pointer-events: none;
  }
</style>
