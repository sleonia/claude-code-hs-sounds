---
import type { Card } from "../data/cards";

interface Props {
  card: Card;
  "data-set"?: string;
}

const { card, ...props } = Astro.props;
const hasSource = card.source.length > 0;
const hasImage = card.image.length > 0;
---

<article class="card" {...props}>
  <div class="content">
    <a
      class="card-link"
      href={hasSource ? card.source : "#"}
      aria-disabled={!hasSource || undefined}
    >
      <div class="art">
        {
          hasImage ? (
            <img src={card.image} alt={card.title} loading="lazy" />
          ) : (
            <div class="art-placeholder">No image</div>
          )
        }
      </div>
        <h2 class="title visually-hidden">{card.title}</h2>
    </a>
    <div class="actions">
      {
        card.audios.map((clip) => (
          <button
            class="button"
            type="button"
            data-state="idle"
            data-label={clip.label}
            data-path={clip.path}
            data-title={card.title}
            aria-pressed="false"
            aria-label={`Play audio: ${card.title} - ${clip.label}`}
          >
            <img src="/ui/play-button.png" alt="" class="play-icon" />
          </button>
        ))
      }
    </div>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .content {
    display: grid;
  }

  .card-link {
    text-decoration: none;
    outline: none;
    transition: transform 0.2s ease;

      &:hover,
      &:focus {
      filter: drop-shadow(rgba(255, 255, 255, 0.6) 0px 0px 15px);
      transform: scale(1.1);
    }
  }

  .card-link[aria-disabled="true"] {
    cursor: default;
  }

  .art img {
    display: block;
    height: clamp(200px, 300px, 300px);
    object-fit: cover;
    transition: transform 0.2s ease;
    filter: drop-shadow(rgba(0, 0, 0, 0.6) 0px 3px 3px);
  }

  .art-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: var(--hs-text-secondary);
    font-size: 0.9rem;
  }

  .title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
    color: var(--hs-text-primary);
    font-family: "Open Sans", Helvetica, Arial, sans-serif;
    font-weight: 700;
    transition: color 0.3s ease;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    padding-inline: 1rem;
  }

  .button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 34px;
    min-height: 34px;
    padding: 0;
    border: 0;
    flex: 0 0 36px;
    cursor: pointer;
    position: relative;
    z-index: 2;
    background-color: transparent;
    background-image: none;

    &:hover, &:focus {
          transform: scale(1.1);
          filter: brightness(1.1);
          outline: none;
    }
  }

  .play-icon {
    width: 60px;
    height: auto;
    object-fit: contain;
    pointer-events: none;
    z-index: 1;

  }
</style>
