---
import type { Card } from '../data/cards';

interface Props {
  card: Card;
  'data-set'?: string;
}

const { card, ...props } = Astro.props;
const hasSource = card.source.length > 0;
const hasImage = card.image.length > 0;
---

<article class="card" {...props}>
  <div class="content">
    <a
      class="card-link"
      href={hasSource ? card.source : '#'}
      aria-disabled={!hasSource || undefined}
    >
      <div class="art">
        {hasImage ? (
          <img src={card.image} alt={card.title} loading="lazy" />
        ) : (
          <div class="art-placeholder">No image</div>
        )}
      </div>
      <div class="meta">
        <div class="set">{card.set}</div>
        <h2 class="title">{card.title}</h2>
      </div>
    </a>
    <div class="actions">
      {card.audios.map((clip) => (
        <button
          class="button"
          type="button"
          data-state="idle"
          data-label={clip.label}
          data-path={clip.path}
          data-title={card.title}
          aria-pressed="false"
        >
          {clip.label}
        </button>
      ))}
    </div>
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: linear-gradient(180deg, rgba(30, 42, 76, 0.96), rgba(11, 17, 33, 0.96));
    border: 1px solid var(--panel-border);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .card:focus-within {
    outline: 3px solid var(--focus);
    outline-offset: 4px;
  }

  .content {
    display: grid;
    gap: 0.9rem;
    padding: 1rem;
  }

  .card-link {
    display: grid;
    gap: 0.9rem;
    color: inherit;
    text-decoration: none;
  }

  .card-link[aria-disabled='true'] {
    cursor: default;
  }

  .card-link:focus-visible {
    outline: 3px solid var(--focus);
    outline-offset: 2px;
  }

  .card-link:hover .title {
    color: var(--accent);
  }

  .card-link:hover .art img {
    transform: translateY(-1px);
  }

  .art {
    aspect-ratio: 375 / 518;
    background: rgba(255, 255, 255, 0.05);
  }

  .art img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .art-placeholder {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .meta {
    display: grid;
    gap: 0.35rem;
  }

  .set {
    color: var(--accent);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.15;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: auto;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    flex: 1 1 auto;
    cursor: pointer;
    color: #1b1730;
    background: linear-gradient(180deg, #ffd772 0%, #f0a43b 100%);
    font: inherit;
  }

  .button[data-state='playing'] {
    background: linear-gradient(180deg, #9ad9ff 0%, #5bb6ff 100%);
  }

  .button:hover {
    color: var(--accent);
  }

  .button:focus-visible {
    outline: 3px solid var(--focus);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .actions {
      flex-direction: column;
    }
  }
</style>
