{
  "name": "hs-sound-pack",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:claude": "node scripts/build.mjs claude",
    "build:opencode": "node scripts/build.mjs opencode",
    "format": "prettier --write \"**/*.{js,ts,json,md}\" \"site/src/**/*.{astro,js,ts,css,scss,json,md}\"",
    "postinstall": "npm run build"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-css-order": "^2.2.0"
  }
}
