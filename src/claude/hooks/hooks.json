{
  "description": "Play sounds when Claude needs user attention",
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_INPUT=\"$(cat)\" node \"$CLAUDE_PLUGIN_ROOT/src/index.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_INPUT=\"$(cat)\" node \"$CLAUDE_PLUGIN_ROOT/src/index.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "HOOK_INPUT=\"$(cat)\" node \"$CLAUDE_PLUGIN_ROOT/src/index.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
